# ============================================
# IT Inventory System — Environment Variables
# ============================================
# Скопіюйте цей файл як .env та заповніть значення:
#   cp .env.example .env

# ── Django ──
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ──
DB_NAME=inventory_db
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://postgres:your-secure-password@localhost:5432/inventory_db

# Зовнішній порт PostgreSQL на хості (якщо 5432 зайнятий)
DB_PORT_EXTERNAL=5433

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379/1

# Зовнішній порт Redis на хості (якщо 6379 зайнятий)
REDIS_PORT_EXTERNAL=6380

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Порт додатку (Nginx) ──
APP_PORT=8081

# ── Email (SMTP) ──
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=inventory@yourcompany.com

# ── Безпека ──
PASSWORD_ENCRYPTION_KEY=
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ── Суперкористувач (автостворення в Docker) ──
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# ── Реєстрація ──
# True — користувачі можуть реєструватися самі
# False — тільки адміністратор може створювати користувачів
ALLOW_REGISTRATION=False

# ── Логування ──
LOG_LEVEL=INFO

# ── Статичні файли ──
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles/
MEDIA_URL=/media/
MEDIA_ROOT=/app/media/

# ── Sentry (опціонально) ──
SENTRY_DSN=
VITE_SENTRY_DSN=
